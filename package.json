{
  "name": "bulai-shop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node start.js",
    "dev": "vite",
    "dev:api": "npm run dev --prefix server",
    "dev:stack": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
