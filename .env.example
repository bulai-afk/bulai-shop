# Яндекс ID (OAuth): https://oauth.yandex.ru/
#
# Локально: Redirect URI http://localhost:5173/auth/yandex/callback
# Продакшен (Vercel): https://bulai-shop.vercel.app/auth/yandex/callback
#   В кабинете OAuth также укажите адрес сайта: https://bulai-shop.vercel.app
#   В Vercel → Settings → Environment Variables задайте VITE_YANDEX_CLIENT_ID (и при необходимости VITE_YANDEX_REDIRECT_URI).
# Rewrite /auth/yandex/callback → callback.html задан в vercel.json.
VITE_YANDEX_CLIENT_ID=

# Необязательно: если отличается от {origin}/auth/yandex/callback
# VITE_YANDEX_REDIRECT_URI=http://localhost:5173/auth/yandex/callback

# Профиль: GET login.yandex.ru/info?format=json + Authorization: OAuth <токен>
# Доп. поля (email, имя, аватар, телефон…) — только если включены права в секции «API Яндекс ID» в oauth.yandex.ru
# В dev Vite проксирует /api/yandex-login-info → login.yandex.ru/info (обход CORS).
# На проде при блокировке CORS укажите URL своего бэкенда-прокси (без /info в конце, если прокси сам дописывает путь):
# VITE_YANDEX_INFO_URL=https://api.example.com/yandex/login-info
#
# Client Secret и jwt_secret только на сервере — не класть в VITE_*.
