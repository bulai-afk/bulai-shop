# Копируйте в .env и подставьте значения (файл .env не коммитить).
PORT=3001
NODE_ENV=development

# MariaDB / MySQL (mysql2 совместим с обоими)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=bulai
DB_PASSWORD=your_password
# Имя БД (только [a-zA-Z0-9_]). При `npm run migrate` база создаётся, если ещё нет.
DB_NAME=bulai_shop

# Dev: Vite по умолчанию на 5173; через запятую можно несколько origin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Яндекс OAuth (публичный client_id; витрина подхватит через GET /api/auth/yandex-config)
# YANDEX_OAUTH_CLIENT_ID=ваш_client_id
# YANDEX_REDIRECT_URI=http://localhost:5173/auth/yandex/callback

# Курс RUB для витрины: https://belarusbank.by/api/kursExchange?city=…
BELARUSBANK_KURS_CITY=Минск
